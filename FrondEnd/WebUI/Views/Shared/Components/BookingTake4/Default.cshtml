@model List<BookingList>
<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <div class="active-member">
                    <div class="table-responsive">
                        <table class="table table-xs mb-0">
                            <thead>
                                <tr>
                                    <th>Ad Soyad</th>
                                    <th>Şehir</th>
                                    <th>Ülke</th>
                                    <th>Durum</th>
                                   
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var x in Model)
                                {
                                    <tr>
                                        
                                        <td>
                                            <span>@x.Name @x.Surname</span>
                                        </td>
                                        <td>
                                            <span>@x.City</span>
                                        </td>
                                        <td>
                                            <span>@x.Country</span>
                                        </td>
                                        @if (x.Status == "Iptal Edildi")
                                        {
                                            <td>
                                                <div>
                                                    <div class="progress" style="height: 6px">
                                                        <div class="progress-bar bg-danger" style="width: 60%"></div>
                                                    </div>
                                                </div>
                                            </td>
                                        }
                                        @if (x.Status == "Onaylandı")
                                        {
                                            <td>
                                                <div>
                                                    <div class="progress" style="height: 6px">
                                                        <div class="progress-bar bg-success" style="width: 100%"></div>
                                                    </div>
                                                </div>
                                            </td>
                                        }
                                        @if (x.Status == "Müşteri Aranacak")
                                        {
                                            <td>
                                                <div>
                                                    <div class="progress" style="height: 6px">
                                                        <div class="progress-bar bg-warning" style="width: 85%"></div>
                                                    </div>
                                                </div>
                                            </td>
                                        }
                                        @if (x.Status == "Müşteri Aranacak")
                                        {
                                            <td><i class="fa fa-circle-o text-warning  mr-2"></i> Müşteri Aranacak</td>
                                        }
                                        @if (x.Status == "Iptal Edildi")
                                        {
                                            <td><i class="fa fa-circle-o text-danger  mr-2"></i> Iptal Edildi</td>
                                        }
                                        @if (x.Status == "Onaylandı")
                                        {
                                            <td><i class="fa fa-circle-o text-success  mr-2"></i> Oynaylandı</td>
                                        }
                                        @* <td>
                                            <span>Last Login</span>
                                            <span class="m-0 pl-3">10 sec ago</span>
                                        </td> *@
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>