@model List<ResultRoomDto>

@{
    string durum = "";
    string description = "";
}
<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
            <h6 class="section-title text-center text-primary text-uppercase">Odalarımız</h6>
            <h1 class="mb-5">Odalarımız <span class="text-primary text-uppercase">Keşf et</span></h1>
        </div>
        <div class="row g-4">
            @foreach (var x in Model)
            {

                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                    <div class="room-item shadow rounded overflow-hidden">
                    <div class="position-relative">
                        <img class="img-fluid" src="@x.RecoverImage" alt="">
                        <small class="position-absolute start-0 top-100 translate-middle-y bg-primary text-white rounded py-1 px-3 ms-4">@x.Price ₺/Gece</small>
                    </div>
                    <div class="p-4 mt-2">
                        <div class="d-flex justify-content-between mb-3">
                            <h5 class="mb-0">@x.Title</h5>
                            <div class="ps-2">
                                @for(int i =0; i < x.View; i++){
                                <small class="fa fa-star text-primary"></small>
                                }
                            </div>
                        </div>
                        <div class="d-flex mb-3">
                            <small class="border-end me-3 pe-3"><i class="fa fa-bed text-primary me-2"></i>@x.BedCount Yatak</small>
                            <small class="border-end me-3 pe-3"><i class="fa fa-bath text-primary me-2"></i>@x.BoatCount Banyo</small>
                                @if(x.Wifi == true)
                                {
                                    durum = "Wifi";
                                }
                                else
                                {
                                    durum = "Wifi yok";
                                }
                                <small><i class="fa fa-wifi text-primary me-2"></i>@durum</small>
                        </div>
                            @if (x.Title == "Tek kişilik oda")
                            {
                                description = " Doğanın içinde doğaya zarar vermeden oluşturduğumuz tek kişilik enfes huzur dolu bir oda ";
                            }
                            @if (x.Title == "iki kişilik oda")
                            {
                                description = "Eşinizle veya sevdiklerinizle beraber keyifli vakik geçireceğınız";
                            }
                            @if (x.Title == "Aile Odasi")
                            {
                                description = " Çocuklarınızla birlikte doya doya keyfini çıkaracağınız aile odamız sicak kahvelerinizle hizmetinizi hazırız  ";
                            }
                            <p class="text-body mb-3">
                                @description
                  
                        </p>
                        <div class="d-flex justify-content-between">
                            <a class="btn btn-sm btn-primary rounded py-2 px-4" href="/Booking/Index/">Detaylar Gör</a>
                            <a class="btn btn-sm btn-dark rounded py-2 px-4" href="/Bookin/Index/">Rezervasyon yap</a>
                        </div>
                    </div>
                </div>
            </div>
           }
        </div>
    </div>
</div>


