@model List<EntityLayer.Concrete.AppUser>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

div class="row">
<div class="col-lg-12">
    <div class="card">
        <div class="card-body">
            <div class="active-member">
                <div class="table-responsive">
                    <table class="table table-xs mb-0">
                        <thead>
                            <tr>
                                <th>Kullanıcı</th>
                                <th>Rol Ata</th>
                                

                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in Model)
                            {
                                <tr>
                                    <td><img src="@x.ImageUrl" class=" rounded-circle mr-3" alt="">@x.Name @x.Surname</td>
                                    <td><a href="/RoleAssign/AssignRole/@x.Id" class="btn btn-warning">Rol Ata</a></td>
                                    
                                   
                                        
                                   
                                </tr>
                            }
                        </tbody>
                    </table>
                    <br />
                    
                </div>
            </div>
        </div>
    </div>
</div>
</div>








