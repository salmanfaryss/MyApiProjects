@model List<ResultWorkLocationDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}


<div class="container-fluid">
    <div class="row">

        <div class="col-lg-12">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Work Location</h4>
                    <div class="table-responsive">
                        <table class="table header-border">
                            <thead>
                                <tr>

                                    <th scope="col">Location Adi</th>
                                    <th scope="col">Şehir</th>          
                                    <th scope="col">Güncelle</th>          
                                    <th scope="col">Sil</th>
                                   
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var x in Model)
                                {

                                    <tr>

                                        <td>@x.WorkLocationName</td>
                                        <td>@x.WorkLocationCity</td>
                                        <td>
                                            <a href="/WorkLocation/UpdateWorkLocation/@x.WorkLocationID" type="button" class="btn mb-1 btn-warning">Güncelle <span class="btn-icon-right"><i class="fa fa-pencil"></i></span> </a>
                                        </td>
                                        <td>
                                            <a href="/WorkLocation/DeleteWorkLocation/@x.WorkLocationID" type="button" class="btn mb-1 btn-danger">Sil <span class="btn-icon-right"><i class="fa fa-close"></i></span> </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <a href="/WorkLocation/AddWorkLocation/" class="btn mb-1 btn-primary"> Yeni Location ekle<span class="btn-icon-right"><i class="fa fa-plus"></i> </span> </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>



