@model List<EntityLayer.Concrete.AppRole>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row">

        <div class="col-lg-12">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Misafirler</h4>
                    <div class="table-responsive">
                        <table class="table header-border">
                            <thead>
                                <tr>

                                    <th scope="col">#</th>
                                    <th scope="col">Role Adı</th>
                                    
                                    <th scope="col">Güncelle</th>
                                    <th scope="col">Sil</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var x in Model)
                                {

                                    <tr>
                                        <th>@x.Id</th>
                                        <td>@x.Name</td>
                                        
                                        <td>
                                            <a href="/Role/UpdateRole/@x.Id" type="button" class="btn mb-1 btn-warning">Güncelle <span class="btn-icon-right"><i class="fa fa-pencil"></i></span> </a>
                                        </td>
                                        <td>
                                            <a href="/Role/DeleteRole/@x.Id" type="button" class="btn mb-1 btn-danger">Sil <span class="btn-icon-right"><i class="fa fa-close"></i></span> </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <a href="/Role/CreateRole/" class="btn mb-1 btn-primary"> Yeni Role Ekle<span class="btn-icon-right"><i class="fa fa-plus"></i> </span> </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>



