@model List<StaffViewModel>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/_AdminLayout.cshtml";
}

<table class="table table-bordered">
    <tr>
        <th>#</th>
        <th>Personel Adi</th>
        <th>Personel Ünvanı</th>
        <th>Personel Görsel</th>
        <th>Sil</th>
        <th>Güncelle</th>
        <th>Detaylar</th>

    </tr>
    @foreach(var x in Model)
    {
        <tr>
            <th>@x.StaffId</th>
            <td>@x.NameSurname</td>
            <td>@x.Title</td>
            <td>
                <img src="@x.ImageUrl" style="width:75px; height:75px;" />
            </td>
            <td><a href="/Staff/DeleteStaff/@x.StaffId" class="btn mb-1 btn-rounded btn-outline-danger">Sil</a></td>
            <td><a href="/Staff/UpdateStaff/@x.StaffId" class="btn mb-1  btn-rounded btn-outline-success">Güncelle</a></td>
            <td><a href="#" class="btn mb-1 btn-outline-dark">Detylar</a></td>
        </tr>
    }
</table>
<a href="/Staff/AddStaff/" class="btn mb-1 btn-outline-info">Yeni Personel Ekle</a>
